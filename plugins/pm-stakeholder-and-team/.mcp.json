{
  "mcpServers": {
    "pm-stakeholder-server": {
      "command": "python3",
      "args": ["../servers/unified_mock_server.py", "--plugin", "pm-stakeholder-and-team"],
      "tools": [
        "get_stakeholder_register",
        "analyze_communication_patterns",
        "get_meeting_decisions",
        "get_feedback_summary"
      ],
      "env": {
        "GRAPH_API_TENANT_ID": "${GRAPH_API_TENANT_ID}",
        "GRAPH_API_CLIENT_ID": "${GRAPH_API_CLIENT_ID}",
        "GRAPH_API_CLIENT_SECRET": "${GRAPH_API_CLIENT_SECRET}",
        "SURVEY_PLATFORM_API_KEY": "${SURVEY_PLATFORM_API_KEY}"
      }
    }
  }
}